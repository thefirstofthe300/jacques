# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/

# Frontend (built assets land in jacques/static/, not committed; the
# directory itself is tracked via jacques/static/.gitkeep so StaticFiles
# has somewhere to mount before the frontend has ever been built)
jacques/static/*
!jacques/static/.gitkeep
frontend/node_modules/

# Runtime state
*.db
*.db-journal
result
result-*

# Environment
.env

# Serena MCP memories (local AI notes, not repo content)
.serena/memories/

# Claude Code local state
.claude/tasks/
